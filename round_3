3: shallow copy and deep_copy.

import copy

# Original nested list
a = [[1, 2], [3, 4]]

# -----------------------
# SHALLOW COPY
# -----------------------
b = copy.copy(a)

# -----------------------
# DEEP COPY
# -----------------------
c = copy.deepcopy(a)

# Modify shallow copy
b[0][0] = 99

# Modify deep copy
c[0][0] = 77

print(a)
# Print results
print("Original a:", a)
print("Shallow copy b:", b)
print("Deep copy c:", c)


